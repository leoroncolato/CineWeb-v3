// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

model Usuario {
  id                  Int        @id @default(autoincrement())
  nome                String
  email               String     @unique
  senhaHash           String
  role                UserRole   @default(USER)
  resetToken          String?    @unique
  resetTokenExpiresAt DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  pedidos             Pedido[]

  @@map("usuarios")
}

model Cinema {
  id          Int      @id @default(autoincrement())
  nome        String
  endereco    String   
  
  listaSalas  Sala[]
  listaFilmes Filme[]
  listaSessao Sessao[]

  @@map("cinemas")
}

model Sala {
  id          Int      @id @default(autoincrement())
  numero      Int      @unique
  capacidade  Int
  poltronas   Json     // aqui um JSON de matriz (ex: [[1,0],[1,1]])
  
  cinemaId    Int?
  cinema      Cinema?  @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  
  sessoes     Sessao[]

  @@map("salas")
}

model Genero {
  id          Int      @id @default(autoincrement())
  nome        String   @unique

  filmes      Filme[]

  @@map("generos")
}

model Filme {
  id                  Int       @id @default(autoincrement())
  titulo              String
  sinopse             String?   @db.Text
  classificacaoEtaria String
  duracao             Int       // Duração em minutos
  elenco              String?   @db.Text

  generoId            Int
  genero              Genero    @relation(fields: [generoId], references: [id])
  
  dataInicialExibicao DateTime  @db.Date
  dataFinalExibicao   DateTime  @db.Date
  
  cinemaId            Int?
  cinema              Cinema?   @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  sessoes             Sessao[]

  @@map("filmes")
}


model Sessao {
  id               Int      @id @default(autoincrement())
  data             DateTime 
  valorIngresso    Float

  filmeId          Int
  filme            Filme    @relation(fields: [filmeId], references: [id], onDelete: Cascade)
  
  salaId           Int
  sala             Sala     @relation(fields: [salaId], references: [id], onDelete: Cascade)

  cinemaId         Int?
  cinema           Cinema?  @relation(fields: [cinemaId], references: [id], onDelete: Cascade)

  ingressos        Ingresso[]

  @@map("sessoes")
}

model Ingresso {
  id           Int      @id @default(autoincrement())
  tipo         String   // "Inteira", "Meia", etc
  valorPago    Float    
  assento      String?
  
  sessaoId     Int
  sessao       Sessao   @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  
  pedidoId     Int?
  pedido       Pedido?  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@unique([sessaoId, assento])
  @@map("ingressos")
}


model LancheCombo {
  id            Int      @id @default(autoincrement())
  nome          String
  descricao     String?  @db.Text
  preco         Float
  qtUnidade     Int
  subtotal      Float
  
  pedidoId      Int?
  pedido        Pedido?  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@map("lanches_combos")
}

model Pedido {
  id                Int           @id @default(autoincrement())
  qtInteira         Int
  qtMeia            Int
  valorTotal        Float
  dataHora          DateTime      @default(now())
  formaPagamento    String?
  statusPagamento   String        @default("APROVADO")
  codigoComprovante String        @unique @default(uuid())
  combos            Json?

  usuarioId         Int?
  usuario           Usuario?      @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  ingressos         Ingresso[]
  lanches           LancheCombo[]

  @@map("pedidos")
}
